{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/daily", "destination": "/index.html" },
    { "source": "/daily/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/upload.ts": {
      "maxDuration": 60
    },
    "api/signed-url.ts": {
      "maxDuration": 10
    },
    "api/photos.ts": {
      "maxDuration": 10
    },
    "api/approve-photo.ts": {
      "maxDuration": 60
    },
    "api/update-photo.ts": {
      "maxDuration": 10
    },
    "api/purge-skips.ts": {
      "maxDuration": 30
    },
    "api/remove-photo.ts": {
      "maxDuration": 30
    },
    "api/health.ts": {
      "maxDuration": 15
    },
    "api/enrich.ts": {
      "maxDuration": 60
    },
    "api/daily.ts": {
      "maxDuration": 30
    }
  }
}
