# Browser-safe (Vite exposes these to the frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Server-side only (scripts and serverless functions — never exposed to browser)
# Supabase
SUPABASE_URL=https://your-project.supabase.co  # Same value as VITE_SUPABASE_URL, but for server-side use
SUPABASE_SERVICE_KEY=your-service-role-key

# R2 Storage
# Two-bucket strategy: public bucket for approved photos (publicly accessible URLs),
# private bucket for pipeline photos (signed URLs only, faces not yet anonymized)
R2_PUBLIC_BUCKET_NAME=what-mile
R2_PRIVATE_BUCKET_NAME=what-mile-private
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
